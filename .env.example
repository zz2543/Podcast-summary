# Core runtime paths. Required; defaults work for local development.
DATA_DIR=data

# SQLite database path. Required; defaults to a file under DATA_DIR.
DB_PATH=data/podsum.sqlite3

# Maximum concurrent jobs. Required; default is safe for SQLite and cloud quotas.
MAX_CONCURRENCY=2

# Application log level. Required; use DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO

# ASR provider. Default doubao requires VOLC_* plus DOUBAO_ASR_* below.
ASR_PROVIDER=doubao

# LLM provider. Default deepseek requires DEEPSEEK_API_KEY below.
LLM_PROVIDER=deepseek

# TTS provider. Default doubao requires VOLC_* plus DOUBAO_TTS_* below.
TTS_PROVIDER=doubao

# Volcengine access key ID. Required for default ASR and TTS.
VOLC_ACCESS_KEY_ID=

# Volcengine secret access key. Required for default ASR and TTS.
VOLC_SECRET_ACCESS_KEY=

# Doubao ASR application ID. Required for default ASR. May match DOUBAO_TTS_APP_ID if one Volcengine app enables both ASR and TTS.
DOUBAO_ASR_APP_ID=

# Doubao ASR access token. Required for default ASR. May match DOUBAO_TTS_ACCESS_TOKEN if one Volcengine app enables both ASR and TTS.
DOUBAO_ASR_ACCESS_TOKEN=

# Doubao ASR cluster. Required for default ASR; confirm the exact model cluster in the Volcengine console.
DOUBAO_ASR_CLUSTER=volcengine_streaming_common

# DeepSeek API key. Required for default LLM_PROVIDER=deepseek.
DEEPSEEK_API_KEY=

# DeepSeek OpenAI-compatible base URL. Required for default LLM_PROVIDER=deepseek.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek chat model. Required for default LLM_PROVIDER=deepseek.
DEEPSEEK_MODEL=deepseek-chat

# Qwen chat model. Required only when LLM_PROVIDER=qwen.
QWEN_LLM_MODEL=qwen-max

# Anthropic model. Required only when LLM_PROVIDER=anthropic; set explicitly to avoid hard-coded model drift.
ANTHROPIC_MODEL=

# Doubao TTS application ID. Required for default TTS. May match DOUBAO_ASR_APP_ID if one Volcengine app enables both ASR and TTS.
DOUBAO_TTS_APP_ID=

# Doubao TTS access token. Required for default TTS. May match DOUBAO_ASR_ACCESS_TOKEN if one Volcengine app enables both ASR and TTS.
DOUBAO_TTS_ACCESS_TOKEN=

# Doubao Chinese voice type. Required for default TTS Chinese output.
DOUBAO_TTS_VOICE_TYPE_ZH=BV700_streaming

# Doubao English voice type. Required for default TTS English output.
DOUBAO_TTS_VOICE_TYPE_EN=BV701_streaming

# Doubao TTS cluster. Required for default TTS.
DOUBAO_TTS_CLUSTER=volcano_tts

# Optional OpenAI API key for ASR_PROVIDER=openai_whisper. Leave blank if unused.
OPENAI_API_KEY=

# Optional Deepgram API key for ASR_PROVIDER=deepgram. Leave blank if unused.
DEEPGRAM_API_KEY=

# Optional Anthropic API key for LLM_PROVIDER=anthropic. Leave blank if unused.
ANTHROPIC_API_KEY=

# Optional DashScope key for Qwen ASR, Qwen LLM, or Qwen-TTS fallback providers. Leave blank if unused.
DASHSCOPE_API_KEY=
