# Core runtime paths. Required; defaults work for local development.
DATA_DIR=data

# SQLite database path. Required; defaults to a file under DATA_DIR.
DB_PATH=data/podsum.sqlite3

# Maximum concurrent jobs. Required; default is safe for SQLite and cloud quotas.
MAX_CONCURRENCY=2

# Application log level. Required; use DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO

# ASR provider. Default doubao requires VOLC_* plus DOUBAO_ASR_* below.
ASR_PROVIDER=doubao

# LLM provider. Default deepseek requires DEEPSEEK_API_KEY below.
LLM_PROVIDER=deepseek

# TTS provider. Default doubao requires VOLC_* plus DOUBAO_TTS_* below.
TTS_PROVIDER=doubao

# Volcengine access key ID. Required for default ASR and TTS; replace placeholder for real processing.
VOLC_ACCESS_KEY_ID=replace-me-volc-access-key-id

# Volcengine secret access key. Required for default ASR and TTS; replace placeholder for real processing.
VOLC_SECRET_ACCESS_KEY=replace-me-volc-secret-access-key

# Doubao ASR application ID. Required for default ASR. May match DOUBAO_TTS_APP_ID if one Volcengine app enables both ASR and TTS.
DOUBAO_ASR_APP_ID=replace-me-doubao-asr-app-id

# Doubao ASR access token. Required for default ASR. May match DOUBAO_TTS_ACCESS_TOKEN if one Volcengine app enables both ASR and TTS.
DOUBAO_ASR_ACCESS_TOKEN=replace-me-doubao-asr-access-token

# Legacy Doubao streaming ASR cluster. Kept only for fallback compatibility; file-mode ASR does not use it.
DOUBAO_ASR_CLUSTER=volcengine_streaming_common

# Doubao recording-file ASR 2.0 resource ID. Required for default file-mode ASR.
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.auc

# Doubao recording-file ASR submit endpoint. Required for default file-mode ASR.
DOUBAO_ASR_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit

# Doubao recording-file ASR query endpoint. Required for default file-mode ASR.
DOUBAO_ASR_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query

# Doubao flash file ASR resource ID for local uploads without a public URL.
# Enable the corresponding recording-file flash/turbo capability in the Volcengine app.
DOUBAO_ASR_FLASH_RESOURCE_ID=volc.bigasr.auc_turbo

# Doubao flash file ASR endpoint for local uploads without a public URL.
DOUBAO_ASR_FLASH_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash

# Poll interval for Doubao recording-file ASR query loop, in seconds.
DOUBAO_ASR_POLL_INTERVAL_SECONDS=3

# Max wait time for Doubao recording-file ASR query loop, in seconds.
DOUBAO_ASR_TIMEOUT_SECONDS=1800

# DeepSeek API key. Required for default LLM_PROVIDER=deepseek; replace placeholder for real processing.
DEEPSEEK_API_KEY=replace-me-deepseek-api-key

# DeepSeek OpenAI-compatible base URL. Required for default LLM_PROVIDER=deepseek.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek chat model. Required for default LLM_PROVIDER=deepseek.
DEEPSEEK_MODEL=deepseek-chat

# Qwen chat model. Required only when LLM_PROVIDER=qwen.
QWEN_LLM_MODEL=qwen-max

# Anthropic model. Required only when LLM_PROVIDER=anthropic; set explicitly to avoid hard-coded model drift.
ANTHROPIC_MODEL=

# Doubao TTS application ID. Required for default TTS. May match DOUBAO_ASR_APP_ID if one Volcengine app enables both ASR and TTS.
DOUBAO_TTS_APP_ID=replace-me-doubao-tts-app-id

# Doubao TTS access token. Required for default TTS. May match DOUBAO_ASR_ACCESS_TOKEN if one Volcengine app enables both ASR and TTS.
DOUBAO_TTS_ACCESS_TOKEN=replace-me-doubao-tts-access-token

# Doubao Chinese voice type. Required for default TTS Chinese output.
DOUBAO_TTS_VOICE_TYPE_ZH=BV700_streaming

# Doubao English voice type. Required for default TTS English output.
DOUBAO_TTS_VOICE_TYPE_EN=BV701_streaming

# Doubao TTS cluster. Required for default TTS.
DOUBAO_TTS_CLUSTER=volcano_tts

# Doubao TTS implementation switch.
#   legacy   → POST /api/v1/tts with BV*_streaming voices (current default).
#   bigmodel → POST DOUBAO_TTS_BIGMODEL_URL with *_uranus_bigtts voices and
#              X-Api-* auth headers. Requires that the BigTTS 2.0 service
#              ("豆包语音合成模型2.0") is enabled on DOUBAO_TTS_APP_ID.
DOUBAO_TTS_MODE=legacy

# Doubao BigTTS 2.0 WebSocket endpoint (bidirectional streaming).
# Only used when DOUBAO_TTS_MODE=bigmodel.
DOUBAO_TTS_BIGMODEL_URL=wss://openspeech.bytedance.com/api/v3/tts/bidirection

# Doubao BigTTS 2.0 resource ID. Only used when DOUBAO_TTS_MODE=bigmodel.
# Values per official doc:
#   seed-tts-2.0         → 语音合成2.0 字符版 (uranus voices, character-billed)
#   seed-tts-1.0         → 语音合成1.0 字符版 (moon voices, character-billed)
#   seed-tts-1.0-concurr → 语音合成1.0 并发版
#   seed-icl-2.0 / 1.0   → 声音复刻
DOUBAO_TTS_BIGMODEL_RESOURCE_ID=seed-tts-2.0

# Output audio format and sample rate for BigTTS 2.0.
DOUBAO_TTS_BIGMODEL_FORMAT=mp3
DOUBAO_TTS_BIGMODEL_SAMPLE_RATE=24000

# Qwen TTS model. Optional fallback when TTS_PROVIDER=qwen.
QWEN_TTS_MODEL=cosyvoice-v2

# Qwen TTS voice. Optional fallback when TTS_PROVIDER=qwen.
QWEN_TTS_VOICE=longxiaochun

# Optional OpenAI API key for ASR_PROVIDER=openai_whisper. Leave blank if unused.
OPENAI_API_KEY=

# Optional Deepgram API key for ASR_PROVIDER=deepgram. Leave blank if unused.
DEEPGRAM_API_KEY=

# Optional Anthropic API key for LLM_PROVIDER=anthropic. Leave blank if unused.
ANTHROPIC_API_KEY=

# Optional DashScope key for Qwen ASR, Qwen LLM, or Qwen-TTS fallback providers. Leave blank if unused.
DASHSCOPE_API_KEY=
